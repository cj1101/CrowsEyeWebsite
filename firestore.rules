rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isResourceOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function isRequestOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Users cannot delete their own accounts via client
    }
    
    // Media items collection
    match /media/{mediaId} {
      allow read: if isResourceOwner();
      allow create: if isRequestOwner();
      allow update: if isResourceOwner();
      allow delete: if isResourceOwner();
      
      // Allow listing user's own media
      allow list: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }
    
    // Galleries collection
    match /galleries/{galleryId} {
      allow read: if isResourceOwner();
      allow create: if isRequestOwner();
      allow update: if isResourceOwner();
      allow delete: if isResourceOwner();
      
      allow list: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }
    
    // Posts collection
    match /posts/{postId} {
      allow read: if isResourceOwner();
      allow create: if isRequestOwner();
      allow update: if isResourceOwner();
      allow delete: if isResourceOwner();
      
      allow list: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }
    
    // Finished content collection
    match /finishedContent/{contentId} {
      allow read: if isResourceOwner();
      allow create: if isRequestOwner();
      allow update: if isResourceOwner();
      allow delete: if isResourceOwner();
      
      allow list: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }
    
    // Schedules collection
    match /schedules/{scheduleId} {
      allow read: if isResourceOwner();
      allow create: if isRequestOwner();
      allow update: if isResourceOwner();
      allow delete: if isResourceOwner();
      
      allow list: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }
    
    // Templates collection
    match /templates/{templateId} {
      allow read: if isResourceOwner();
      allow create: if isRequestOwner();
      allow update: if isResourceOwner();
      allow delete: if isResourceOwner();
      
      allow list: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }
    
    // Analytics collection
    match /analytics/{analyticsId} {
      allow read: if isResourceOwner();
      allow create: if isRequestOwner();
      allow update: if isResourceOwner();
      allow delete: if false; // Analytics should not be deleted
      
      allow list: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }
    
    // Google Photos connections
    match /googlePhotosConnections/{connectionId} {
      allow read: if isResourceOwner();
      allow create: if isRequestOwner() && 
        !exists(/databases/$(database)/documents/googlePhotosConnections/$(request.auth.uid));
      allow update: if isResourceOwner();
      allow delete: if isResourceOwner();
    }
    
    // Knowledge base (AI memory)
    match /knowledgeBase/{knowledgeId} {
      allow read: if isResourceOwner();
      allow create: if isRequestOwner();
      allow update: if isResourceOwner();
      allow delete: if isResourceOwner();
      
      allow list: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }
    
    // Context files for AI
    match /contextFiles/{fileId} {
      allow read: if isResourceOwner();
      allow create: if isRequestOwner();
      allow update: if isResourceOwner();
      allow delete: if isResourceOwner();
      
      allow list: if isAuthenticated() && 
        request.auth.uid == resource.data.userId;
    }
  }
} 